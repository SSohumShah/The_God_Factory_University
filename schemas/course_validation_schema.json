{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Arcane University Course",
  "description": "Validation schema for course JSON imports.",
  "type": "object",
  "required": ["title", "modules"],
  "properties": {
    "course_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "credits": { "type": "integer", "minimum": 1 },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "lectures"],
        "properties": {
          "module_id": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "lectures": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title"],
              "properties": {
                "lecture_id": { "type": "string" },
                "title": { "type": "string", "minLength": 1 },
                "duration_min": { "type": "number", "minimum": 1 },
                "prerequisites": { "type": "array", "items": { "type": "string" } },
                "learning_objectives": { "type": "array", "items": { "type": "string" } },
                "core_terms": { "type": "array", "items": { "type": "string" } },
                "video_recipe": {
                  "type": "object",
                  "properties": {
                    "narrative_arc": { "type": "array", "items": { "type": "string" } },
                    "scene_blocks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["narration_prompt"],
                        "properties": {
                          "block_id": { "type": "string" },
                          "duration_s": { "type": "number", "minimum": 1 },
                          "narration_prompt": { "type": "string", "minLength": 1 },
                          "visual_prompt": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
